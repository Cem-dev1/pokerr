# Copy to .env.local (local) OR set these in Vercel → Settings → Environment Variables.
# NEXT_PUBLIC_* values are the Supabase project URL + publishable anon key.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Prisma/SQLite (offline data layer). Not needed for Vercel (Supabase handles online).
DATABASE_URL="file:./dev.db"
